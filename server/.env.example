PORT=5000
MONGODB_URI=mongodb://localhost:27017/classmentor-ai
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Groq API (free tier - get key at console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Use mock AI when no API key (set to false when using Groq)
USE_MOCK_AI=false

# SMTP (for welcome email & forgot password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=classMentor AI <your-email@gmail.com>
APP_URL=http://localhost:3000
